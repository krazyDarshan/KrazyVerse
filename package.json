{
  "name": "krazyverse",
  "version": "0.1.0",
  "private": true,
  "description": "KrazyVerse monorepo: mobile, web, admin, API, and shared contracts.",
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@expo/vector-icons": "14.0.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "expo-font": "12.0.10"
  },
  "scripts": {
    "dev": "npm run dev --workspace @krazyverse/api",
    "dev:api": "npm run dev --workspace @krazyverse/api",
    "dev:web": "npm run dev --workspace @krazyverse/web",
    "dev:admin": "npm run dev --workspace @krazyverse/admin",
    "dev:mobile": "dotenv -e .env -- npm run start --workspace @krazyverse/mobile",
    "dev:mobile:lan": "dotenv -e .env -- npm run start:lan --workspace @krazyverse/mobile",
    "dev:mobile:lan:clear": "powershell -ExecutionPolicy Bypass -File scripts/start-mobile-lan.ps1",
    "dev:mobile:diag": "powershell -ExecutionPolicy Bypass -File scripts/mobile-network-diag.ps1",
    "dev:mobile:tunnel": "dotenv -e .env -- npm run start:tunnel --workspace @krazyverse/mobile",
    "dev:mobile:tunnel:clear": "powershell -ExecutionPolicy Bypass -File scripts/start-mobile-tunnel.ps1",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "jest --runInBand",
    "db:generate": "npm run db:generate --workspace @krazyverse/api",
    "db:migrate": "npm run db:migrate --workspace @krazyverse/api",
    "db:studio": "npm run db:studio --workspace @krazyverse/api"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.4",
    "typescript": "~5.3.3"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  }
}

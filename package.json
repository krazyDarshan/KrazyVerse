{
  "name": "krazyverse",
  "version": "0.1.0",
  "private": true,
  "description": "KrazyVerse monorepo: mobile, web, admin, API, and shared contracts.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @krazyverse/api",
    "dev:api": "npm run dev --workspace @krazyverse/api",
    "dev:web": "npm run dev --workspace @krazyverse/web",
    "dev:admin": "npm run dev --workspace @krazyverse/admin",
    "dev:mobile": "npm run start --workspace @krazyverse/mobile",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "jest --runInBand",
    "db:generate": "npm run db:generate --workspace @krazyverse/api",
    "db:migrate": "npm run db:migrate --workspace @krazyverse/api",
    "db:studio": "npm run db:studio --workspace @krazyverse/api"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.4",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  }
}

{
  "name": "@krazyverse/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts",
    "build": "dotenv -e ../../.env -- prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev --name init",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "test": "jest --config ../../jest.config.cjs --runInBand"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@aws-sdk/client-s3": "^3.620.1",
    "@clerk/backend": "^1.7.1",
    "@elastic/elasticsearch": "^8.14.0",
    "@krazyverse/shared": "file:../../packages/shared",
    "@prisma/client": "^5.17.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.10",
    "cloudinary": "^2.4.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^12.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "nodemailer": "^6.9.14",
    "replicate": "^0.32.1",
    "socket.io": "^4.7.5",
    "speakeasy": "^2.0.0",
    "twilio": "^5.2.2",
    "typesense": "^1.8.2",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.12",
    "@types/nodemailer": "^6.4.15",
    "@types/speakeasy": "^2.0.10",
    "prisma": "^5.17.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.16.2",
    "typescript": "~5.3.3"
  }
}

{
  "expo": {
    "name": "KrazyVerse",
    "slug": "krazyverse",
    "scheme": "krazyverse",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.krazyverse.app"
    },
    "android": {
      "package": "com.krazyverse.app",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      }
    },
    "plugins": [
      "expo-camera",
      "expo-local-authentication",
      "expo-notifications",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "http://localhost:4000/api/v1"
    }
  }
}

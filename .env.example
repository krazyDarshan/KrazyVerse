# Shared
NODE_ENV=development
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
MOBILE_DEEP_LINK_SCHEME=krazyverse
API_PORT=4000
API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
